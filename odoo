def build_odoo(config, no_cache):
    """Generate all config files and build Docker images."""
    print("\n=== Generando archivos de configuración ===\n")

    # 1. Generate Dockerfiles for each unique Odoo version
    unique_versions = get_unique_odoo_versions(config)
    print(f"Versiones de Odoo detectadas: {', '.join(sorted(unique_versions))}")
    dockerfile_map = generate_dockerfiles(BASE_PATH, unique_versions)

    # 2. Generate docker-compose.generated.yml
    generate_compose(BASE_PATH, config, dockerfile_map)

    # 3. Generate nginx config
    generate_nginx_config(BASE_PATH, config)

    # 4. Build images
    print("\n=== Construyendo imágenes Docker ===\n")
    if no_cache:
        _docker_compose("build", "--no-cache")
    else:
        _docker_compose("build")

    print("\n✅ Build completado.\n")


def start_odoo(config, instance=None):
    """Start database(s), Odoo instance(s), and nginx."""
    if instance:
        print(f"\n=== Iniciando instancia: {instance} ===\n")
    else:
        print("\n=== Iniciando todas las instancias ===\n")

    db_services = _get_db_services(config, instance)
    odoo_services = _get_instance_services(config, instance)

    # Start managed DBs
    if db_services:
        print("→ Iniciando base(s) de datos...")
        _docker_compose("up", "-d", *db_services)

    # Start Odoo instances
    print("\n→ Iniciando instancia(s) Odoo...")
    _docker_compose("up", "-d", *odoo_services)

    # Fix filestore permissions
    for svc in odoo_services:
        os.system(
            f"docker exec -u root {svc} chown -R odoo:odoo /home/odoo/data 2>/dev/null || true"
        )

    # Start nginx
    print("\n→ Iniciando Nginx...")
    _docker_compose("up", "-d", "nginx")

    # Show URLs
    print("\n✅ Instancias en ejecución:\n")
    instances_to_show = [instance] if instance else config["instances"].keys()
    for name in instances_to_show:
        port = config["instances"][name]["external_port"]
        print(f"  • {name}: http://localhost:{port}")

    print()


def stop_odoo(config, instance=None):
    """Stop Odoo instance(s) and optionally their databases."""
    if instance:
        print(f"\n=== Deteniendo instancia: {instance} ===\n")
        odoo_services = _get_instance_services(config, instance)
        _docker_compose("stop", *odoo_services)
        # Check if the DB is still used by other running instances
        db_name = config["instances"][instance]["database"]
        db_conf = config["databases"][db_name]
        if db_conf.get("create_container", True):
            other_users = [
                name for name, conf in config["instances"].items()
                if conf["database"] == db_name and name != instance
            ]
            if not other_users:
                print(f"\n→ Deteniendo base de datos {db_name} (sin otras instancias que la usen)...")
                _docker_compose("stop", f"db-{db_name}")
            else:
                print(f"\n→ Base de datos {db_name} no se detiene (usada por: {', '.join(other_users)})")
    else:
        print("\n=== Deteniendo todas las instancias ===\n")
        _docker_compose("down")

    print("\n🛑 Detenido.\n")


def restart_odoo(config, instance=None):
    """Restart Odoo instance(s)."""
    stop_odoo(config, instance)
    start_odoo(config, instance)


def remove_odoo(config, instance=None):
    """Remove containers and volumes."""
    if instance:
        target = f"instancia '{instance}'"
    else:
        target = "TODAS las instancias y bases de datos"

    do_continue = input(
        f"⚠️  Esto eliminará {target} y sus datos. ¿Deseas continuar? (s/n): "
    )
    if do_continue.lower() != "s":
        print("Operación cancelada.")
        return

    if instance:
        odoo_services = _get_instance_services(config, instance)
        for svc in odoo_services:
            os.system(f"docker compose -f {COMPOSE_FILE} rm -s -v -f {svc}")
    else:
        _docker_compose("down", "-v", "--remove-orphans")

    print("\n🛑 Eliminado.\n")


def run_bash(config, instance):
