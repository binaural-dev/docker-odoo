def init_addons(config, instance=None):
    """Clone required repositories for instance(s)."""
    instances_to_init = [instance] if instance else list(config["instances"].keys())
    sources_path = os.path.join(BASE_PATH, "src")

    for inst_name in instances_to_init:
        inst_conf = config["instances"][inst_name]
        odoo_conf = resolve_instance_config(inst_conf, config)
        addons = odoo_conf.get("addons", [])
        odoo_version = inst_conf["odoo_version"]

        print(f"\n=== Init para instancia: {inst_name} (Odoo {odoo_version}) ===")
        for addon_path in addons:
            # addon_path is like "src/enterprise" or "src/custom/bananera"
            local_path = os.path.join(BASE_PATH, addon_path)
            if os.path.isdir(local_path):
                print(f"  ✓ {addon_path} ya existe")
            else:
                print(f"  → {addon_path} no encontrado. Créalo manualmente o clona el repositorio correspondiente en {local_path}")

    print()


def sync(repo_names, branch, show=False):
    """Sync repositories and their submodules."""
    if isinstance(repo_names, str):
        repo_names = [repo_names]

    for repo_name in repo_names:
        repo_path = os.path.join(BASE_PATH, "src", "custom", repo_name)
        if not os.path.isdir(repo_path):
            print(f"Error: Repositorio '{repo_name}' no encontrado en src/custom/")
            continue

        print(f"\n=== Sincronizando {repo_name} (Rama: {branch}) ===")
        os.chdir(repo_path)
        
        stdout = subprocess.DEVNULL if not show else None
        
        try:
            print(f"→ Guardando cambios locales (stash)...")
            subprocess.run(["git", "stash"], stdout=stdout)
            
            print(f"→ Cambiando a rama {branch}...")
            subprocess.run(["git", "checkout", branch], stdout=stdout)
            
            print(f"→ Trayendo últimos cambios (pull)...")
            subprocess.run(["git", "pull", "origin", branch], stdout=stdout)
            
            print(f"→ Actualizando submódulos (init --recursive)...")
            # Using --init --recursive to ensure all levels are updated
            subprocess.run(["git", "submodule", "update", "--init", "--recursive"], stdout=stdout)
            
            print(f"✅ {repo_name} sincronizado.")
        except Exception as e:
            print(f"❌ Error sincronizando {repo_name}: {e}")
        finally:
            os.chdir(BASE_PATH)


