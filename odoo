def fix_filestore(config, instance=None):
    """Fix filestore ownership."""
    services = _get_instance_services(config, instance)
    for svc in services:
        print(f"→ Corrigiendo permisos en {svc}...")
        os.system(
            f"docker exec -u root {svc} chown -R odoo:odoo /home/odoo/data"
        )
    print("\n✅ Permisos corregidos.\n")


