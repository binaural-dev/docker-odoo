#!/usr/bin/env python3

"""
Multi-instance Odoo Docker management CLI.
Reads instances.json and generates/manages Docker containers for multiple Odoo instances.
"""

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

# Add .resources to path for generators
BASE_PATH = str(Path(__file__).resolve().parent)
sys.path.insert(0, os.path.join(BASE_PATH, ".resources"))

from generators.config_loader import (
    load_config,
    resolve_instance_config,
    resolve_db_config,
    get_db_host,
    get_unique_odoo_versions,
    get_managed_databases,
)
from generators.dockerfile_generator import generate_dockerfiles
from generators.compose_generator import generate_compose
from generators.nginx_generator import generate_nginx_config

COMPOSE_FILE = "docker-compose.generated.yml"


def _docker_compose(*args):
    """Run docker compose with the generated file."""
    cmd = f"docker compose -f {COMPOSE_FILE} {' '.join(args)}"
    print(cmd)
    os.system(cmd)


def _get_instance_services(config, instance=None):
    """Get the list of docker compose service names for an instance (or all)."""
    if instance:
        if instance not in config["instances"]:
            print(f"Error: Instancia '{instance}' no existe en instances.json")
            print(f"Instancias disponibles: {', '.join(config['instances'].keys())}")
            sys.exit(1)
        return [f"odoo-{instance}"]
    return [f"odoo-{name}" for name in config["instances"]]


def _get_db_services(config, instance=None):
    """Get managed DB services needed for an instance (or all)."""
    if instance:
        inst_conf = config["instances"][instance]
        db_name = inst_conf["database"]
        db_conf = config["databases"][db_name]
        if db_conf.get("create_container", True):
            return [f"db-{db_name}"]
        return []
    # All managed DBs
    return [f"db-{name}" for name in get_managed_databases(config)]


# ============================================================
# Commands
# ============================================================


def build_odoo(config, no_cache):
    """Generate all config files and build Docker images."""
    print("\n=== Generando archivos de configuración ===\n")

    # 1. Generate Dockerfiles for each unique Odoo version
    unique_versions = get_unique_odoo_versions(config)
    print(f"Versiones de Odoo detectadas: {', '.join(sorted(unique_versions))}")
    dockerfile_map = generate_dockerfiles(BASE_PATH, unique_versions)

    # 2. Generate docker-compose.generated.yml
    generate_compose(BASE_PATH, config, dockerfile_map)

    # 3. Generate nginx config
    generate_nginx_config(BASE_PATH, config)

    # 4. Build images
    print("\n=== Construyendo imágenes Docker ===\n")
    if no_cache:
        _docker_compose("build", "--no-cache")
    else:
        _docker_compose("build")

    print("\n✅ Build completado.\n")


def start_odoo(config, instance=None):
    """Start database(s), Odoo instance(s), and nginx."""
    if instance:
        print(f"\n=== Iniciando instancia: {instance} ===\n")
    else:
        print("\n=== Iniciando todas las instancias ===\n")

    db_services = _get_db_services(config, instance)
    odoo_services = _get_instance_services(config, instance)

    # Start managed DBs
    if db_services:
        print("→ Iniciando base(s) de datos...")
        _docker_compose("up", "-d", *db_services)

    # Start Odoo instances
    print("\n→ Iniciando instancia(s) Odoo...")
    _docker_compose("up", "-d", *odoo_services)

    # Fix filestore permissions
    for svc in odoo_services:
        os.system(
            f"docker exec -u root {svc} chown -R odoo:odoo /home/odoo/data 2>/dev/null || true"
        )

    # Start nginx
    print("\n→ Iniciando Nginx...")
    _docker_compose("up", "-d", "nginx")

    # Show URLs
    print("\n✅ Instancias en ejecución:\n")
    instances_to_show = [instance] if instance else config["instances"].keys()
    for name in instances_to_show:
        port = config["instances"][name]["external_port"]
        print(f"  • {name}: http://localhost:{port}")

    print()


def stop_odoo(config, instance=None):
    """Stop Odoo instance(s) and optionally their databases."""
    if instance:
        print(f"\n=== Deteniendo instancia: {instance} ===\n")
        odoo_services = _get_instance_services(config, instance)
        _docker_compose("stop", *odoo_services)
        # Check if the DB is still used by other running instances
        db_name = config["instances"][instance]["database"]
        db_conf = config["databases"][db_name]
        if db_conf.get("create_container", True):
            other_users = [
                name for name, conf in config["instances"].items()
                if conf["database"] == db_name and name != instance
            ]
            if not other_users:
                print(f"\n→ Deteniendo base de datos {db_name} (sin otras instancias que la usen)...")
                _docker_compose("stop", f"db-{db_name}")
            else:
                print(f"\n→ Base de datos {db_name} no se detiene (usada por: {', '.join(other_users)})")
    else:
        print("\n=== Deteniendo todas las instancias ===\n")
        _docker_compose("down")

    print("\n🛑 Detenido.\n")


def restart_odoo(config, instance=None):
    """Restart Odoo instance(s)."""
    stop_odoo(config, instance)
    start_odoo(config, instance)


def remove_odoo(config, instance=None):
    """Remove containers and volumes."""
    if instance:
        target = f"instancia '{instance}'"
    else:
        target = "TODAS las instancias y bases de datos"

    do_continue = input(
        f"⚠️  Esto eliminará {target} y sus datos. ¿Deseas continuar? (s/n): "
    )
    if do_continue.lower() != "s":
        print("Operación cancelada.")
        return

    if instance:
        odoo_services = _get_instance_services(config, instance)
        for svc in odoo_services:
            os.system(f"docker compose -f {COMPOSE_FILE} rm -s -v -f {svc}")
    else:
        _docker_compose("down", "-v", "--remove-orphans")

    print("\n🛑 Eliminado.\n")


def run_bash(config, instance):
    """Open bash in an Odoo instance container."""
    container = f"odoo-{instance}"
    print(f"docker exec -u root -it {container} bash")
    os.system(f"docker exec -u root -it {container} bash")


def bash_update_modules(config, instance, dbname, modules="all"):
    """Update Odoo modules in an instance."""
    container = f"odoo-{instance}"
    cmd = f"docker exec -u root -it {container} odoo --stop-after-init -p 90 --workers=0 -u {modules} -d {dbname}"
    print(cmd)
    os.system(cmd)


def show_logs(config, instance=None):
    """Show logs for instance(s)."""
    if instance:
        services = _get_instance_services(config, instance)
        db_services = _get_db_services(config, instance)
        all_services = db_services + services
        _docker_compose("logs", "--tail=10", "-f", *all_services)
    else:
        _docker_compose("logs", "--tail=10", "-f")


def list_containers(config):
    """List running containers."""
    _docker_compose("ps")


def fix_filestore(config, instance=None):
    """Fix filestore ownership."""
    services = _get_instance_services(config, instance)
    for svc in services:
        print(f"→ Corrigiendo permisos en {svc}...")
        os.system(
            f"docker exec -u root {svc} chown -R odoo:odoo /home/odoo/data"
        )
    print("\n✅ Permisos corregidos.\n")


def psql_connect(config, instance, dbname):
    """Connect to psql in an instance."""
    inst_conf = config["instances"][instance]
    db_conf = resolve_db_config(inst_conf, config)
    db_host = get_db_host(inst_conf["database"], db_conf)
    db_user = db_conf["user"]
    db_password = db_conf["password"]
    db_port = db_conf["port"]
    container = f"odoo-{instance}"

    os.system(
        f"docker exec -it -e PGPASSWORD={db_password} {container} "
        f"psql --host {db_host} --port {db_port} -U {db_user} -d {dbname}"
    )


def init_addons(config, instance=None):
    """Clone required repositories for instance(s)."""
    instances_to_init = [instance] if instance else list(config["instances"].keys())
    sources_path = os.path.join(BASE_PATH, "src")

    for inst_name in instances_to_init:
        inst_conf = config["instances"][inst_name]
        odoo_conf = resolve_instance_config(inst_conf, config)
        addons = odoo_conf.get("addons", [])
        odoo_version = inst_conf["odoo_version"]

        print(f"\n=== Init para instancia: {inst_name} (Odoo {odoo_version}) ===")
        for addon_path in addons:
            # addon_path is like "src/enterprise" or "src/custom/bananera"
            local_path = os.path.join(BASE_PATH, addon_path)
            if os.path.isdir(local_path):
                print(f"  ✓ {addon_path} ya existe")
            else:
                print(f"  → {addon_path} no encontrado. Créalo manualmente o clona el repositorio correspondiente en {local_path}")

    print()


def sync(repo_name, branch, show=False):
    """Sync submodules for a custom repository."""
    path = BASE_PATH
    src_path = path + "/src/"
    repo_path = src_path + "custom/" + repo_name
    if not os.path.isdir(repo_path):
        print("No se encuentra el repositorio solicitado!")
        return
    os.chdir(repo_path)

    stdout = subprocess.DEVNULL
    stderr = subprocess.STDOUT

    if show:
        stdout = None
        stderr = None
    print("\r %s: Guardando cambios actuales... " % (repo_name), end=" " * 50)
    value = subprocess.run(["git", "status"], capture_output=True)
    values_lines = value.stdout.decode().split("\n")
    branch_now = values_lines[0].replace("On branch ", "")

    submodules = ["integra-addons", "third-party-addons", "odoo-venezuela"]
    submodule_gitmodules_map = {"odoo-venezuela": "homo-addons"}
    print(
        "\r %s: Cambiando a %s                           " % (repo_name, branch),
        end=" " * 50,
    )
    subprocess.run(["git", "stash"], stdout=stdout, stderr=stderr)
    subprocess.run(["git", "checkout", branch], stdout=stdout, stderr=stderr)
    subprocess.run(["git", "pull"], stdout=stdout, stderr=stderr)
    print(
        "\r %s: Actualizando %s                          " % (repo_name, branch),
        end=" " * 50,
    )
    for submodule in submodules:
        subprocess.run(
            ["git", "reset", "HEAD", "--", submodule], stdout=stdout, stderr=stderr
        )
        subprocess.run(
            ["git", "-C", submodule, "stash", "--include-untracked"],
            stdout=stdout,
            stderr=stderr,
        )
        subprocess.run(
            ["git", "submodule", "update", "--init", "--force", "--", submodule],
            stdout=stdout,
            stderr=stderr,
        )
        print(
            "\r %s: Obteniendo submodulos de %s                     "
            % (repo_name, branch),
            end=" " * 50,
        )

    print("")
    for submodule in submodules:
        if not show:
            print("\r %s Sincronizando... " % (submodule), end="")
        commit = ""
        submodule_internal = submodule_gitmodules_map.get(submodule, submodule)
        try:
            with open(
                repo_path + "/.git/modules/" + submodule_internal + "/HEAD", "r"
            ) as Modules:
                line = Modules.readlines()[0]
                if line.startswith("ref:"):
                    commit = line.split("/")[2].replace("\n", "")
                else:
                    commit = line.replace("\n", "")

            if not commit:
                continue
            submodule_path = src_path + submodule
            os.chdir(submodule_path)
            subprocess.run(["git", "stash"], stdout=stdout, stderr=stderr)
            subprocess.run(["git", "fetch"], stdout=stdout, stderr=stderr)
            response = subprocess.run(["git", "checkout", commit], capture_output=True)
            success = response.stderr.decode()

            if commit[:8] not in success and commit[:7] not in success:
                print(commit.encode())
                print(success.encode())
                print("ERROR")
                raise Exception("Error")

            if not show:
                print(
                    "\r %s ( %s ) Sincronizado ✅" % (submodule, commit), end=" " * 30
                )
        except Exception as a:
            print(a)
            if not show:
                print(
                    "\r %s ( %s ) Sincronizado Fallido ❌" % (submodule, commit),
                    end=" " * 30,
                )

        if not show:
            print("")

    os.chdir(repo_path)
    subprocess.run(["git", "checkout", branch_now], stdout=stdout, stderr=stderr)
    subprocess.run(["git", "stash", "pop"], stdout=stdout, stderr=stderr)


