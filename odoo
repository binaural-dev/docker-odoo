def get_databases(config, instance):
    """Fetch database names from the postgres container of an instance."""
    try:
        inst_conf = config["instances"][instance]
        db_conf = resolve_db_config(inst_conf, config)
        db_host = get_db_host(inst_conf["database"], db_conf)
        db_user = db_conf["user"]
        db_password = db_conf["password"]
        db_port = db_conf["port"]
        container = f"odoo-{instance}"

        # Try to get databases from postgres
        cmd = (
            f"docker exec -e PGPASSWORD={db_password} {container} "
            f"psql --host {db_host} --port {db_port} -U {db_user} -d postgres -At -c "
            f"\"SELECT datname FROM pg_database WHERE datistemplate = false AND datname NOT IN ('postgres', 'template1');\" 2>/dev/null"
        )
        output = subprocess.check_output(cmd, shell=True).decode().strip()
        if output:
            return sorted(output.split("\n"))
    except Exception:
        pass
    return []


def get_users(config, instance, dbname):
    """Fetch active users from a specific database."""
    try:
        inst_conf = config["instances"][instance]
        db_conf = resolve_db_config(inst_conf, config)
        db_host = get_db_host(inst_conf["database"], db_conf)
        db_user = db_conf["user"]
        db_password = db_conf["password"]
        db_port = db_conf["port"]
        container = f"odoo-{instance}"

        cmd = (
            f"docker exec -e PGPASSWORD={db_password} {container} "
            f"psql --host {db_host} --port {db_port} -U {db_user} -d {dbname} -At -c "
            f"\"SELECT login FROM res_users WHERE active = true ORDER BY login;\" 2>/dev/null"
        )
        output = subprocess.check_output(cmd, shell=True).decode().strip()
        if output:
            return sorted(output.split("\n"))
    except Exception:
        pass
    return []


def get_custom_repos():
    """List directories in src/custom/."""
    custom_path = os.path.join(BASE_PATH, "src", "custom")
    if not os.path.isdir(custom_path):
        return []
    return sorted([
        d for d in os.listdir(custom_path) 
        if os.path.isdir(os.path.join(custom_path, d))
    ])


def get_custom_modules(config, instance):
    """List custom modules found in the addons paths of an instance."""
    try:
        inst_conf = config["instances"][instance]
        odoo_conf = resolve_instance_config(inst_conf, config)
        addons_paths = odoo_conf.get("addons", [])
        
        modules = []
        for path in addons_paths:
            full_path = os.path.join(BASE_PATH, path)
            if not os.path.isdir(full_path):
                continue
            for item in os.listdir(full_path):
                item_path = os.path.join(full_path, item)
                if os.path.isdir(item_path):
                    if os.path.exists(os.path.join(item_path, "__manifest__.py")) or \
                       os.path.exists(os.path.join(item_path, "__openerp__.py")):
                        modules.append(item)
        return sorted(list(set(modules)))
    except Exception:
        pass
    return []


def prompt_selection(options, title, multi=False):
    """
    Generic interactive selection menu.
    options: list of (label, value) tuples.
    title: string to display.
    multi: boolean, if true allows multiple selection.
    returns: selected value (or list of values if multi).
    """
    if not options:
        return [] if multi else None

    def fallback_prompt():
        print(f"\n{title}:")
        for i, (text, _) in enumerate(options, 1):
            print(f"  {i}. {text}")
        if multi:
            print("  (Ingresa números separados por coma, ej: 1,3,4 o 'all' para todos)")
        while True:
            try:
                choice = input("\nSelección: ").strip().lower()
                if not choice:
                    if multi: return []
                    continue
                if multi and choice == 'all':
                    return [val for _, val in options]
                if multi:
                    indices = [int(x.strip()) for x in choice.replace(',', ' ').split() if x.strip()]
                    selected = []
                    for idx in indices:
                        if 1 <= idx <= len(options):
                            selected.append(options[idx-1][1])
                    return selected
                else:
                    idx = int(choice)
                    if 1 <= idx <= len(options):
                        return options[idx-1][1]
                print("Selección inválida.")
            except ValueError:
                print("Por favor ingresa un valor válido.")
            except (KeyboardInterrupt, EOFError):
                print("\nOperación cancelada.")
                sys.exit(0)

    if not sys.stdin.isatty():
        return fallback_prompt()

    try:
        import tty
        import termios
    except ImportError:
        return fallback_prompt()

    def getch():
        fd = sys.stdin.fileno()
        try:
            old_settings = termios.tcgetattr(fd)
        except Exception:
            return sys.stdin.read(1)
        try:
            tty.setraw(fd)
            ch = sys.stdin.read(1)
            if ch == '\x1b':
                ch += sys.stdin.read(2)
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)
        return ch

    current_idx = 0
    selected_indices = set()
    input_buffer = ""
    lines_to_clear = len(options) + 1

    print(f"\n{title}:")
    
    def render_menu():
        sys.stdout.write("\r")
        for i, (text, _) in enumerate(options):
            prefix = "❯ " if i == current_idx else "  "
            if multi:
                mark = "[x] " if i in selected_indices else "[ ] "
                prefix += mark
            
            if i == current_idx:
                sys.stdout.write(f"\033[92m{prefix}{text}\033[0m\033[K\n")
            else:
                sys.stdout.write(f"{prefix}{text}\033[K\n")
        
        if multi:
            sys.stdout.write(f"\033[90m(Espacio: seleccionar, Enter: confirmar, A: todos, N: ninguno)\033[0m\033[K")
        else:
            sys.stdout.write(f"Opción [ {input_buffer} ]: \033[K")
        sys.stdout.flush()

    sys.stdout.write("\033[?25l") # Ocultar cursor
    try:
        render_menu()
        while True:
            ch = getch()
            if ch == '\x03': # Ctrl+C
                raise KeyboardInterrupt
            elif ch in ('\r', '\n'):
                sys.stdout.write("\n")
                break
            elif ch == ' ': # Espacio
                if multi:
                    if current_idx in selected_indices:
                        selected_indices.remove(current_idx)
                    else:
                        selected_indices.add(current_idx)
            elif ch in ('a', 'A'):
                if multi:
                    selected_indices = set(range(len(options)))
            elif ch in ('n', 'N'):
                if multi:
                    selected_indices.clear()
            elif ch == '\x1b[A': # Arriba
                current_idx = (current_idx - 1) % len(options)
                input_buffer = ""
            elif ch == '\x1b[B': # Abajo
                current_idx = (current_idx + 1) % len(options)
                input_buffer = ""
            elif ch in ('\x7f', '\b'): # Backspace
                input_buffer = input_buffer[:-1]
            elif len(ch) == 1 and ch.isdigit():
                input_buffer += ch
                try:
                    num_val = int(input_buffer)
                    if 1 <= num_val <= len(options):
                        current_idx = num_val - 1
                except ValueError:
                    pass
            
            # Regresar cursor arriba
            sys.stdout.write(f"\033[{lines_to_clear}F")
            render_menu()
            
    except Exception:
        sys.stdout.write("\033[?25h\nOperación cancelada.\n")
        sys.exit(0)
    finally:
        sys.stdout.write("\033[?25h") # Mostrar cursor
        
    if multi:
        return [options[i][1] for i in sorted(list(selected_indices))]
    return options[current_idx][1]


def prompt_for_instance(config, action):
    instances = list(config.get("instances", {}).keys())
    if not instances:
        print("No hay instancias configuradas.")
        sys.exit(1)

    allow_all_actions = {"start", "stop", "restart", "logs", "remove", "fix-files", "init"}
    allow_all = action in allow_all_actions

    options = []
    if allow_all:
        options.append(("Todas las instancias", None))
    for name in instances:
        options.append((name, name))
    
    return prompt_selection(options, "Selecciona una instancia (Usa las flechas, números y Enter para confirmar)")


def prompt_for_database(config, instance):
    databases = get_databases(config, instance)
    if not databases:
        return input(f"\nNo se pudieron auto-detectar bases de datos. Ingresa el nombre de la base de datos para '{instance}': ").strip()
    
    options = [(db, db) for db in databases]
    return prompt_selection(options, f"Selecciona base de datos para '{instance}'")


def prompt_for_modules(config, instance):
    modules = get_custom_modules(config, instance)
    if not modules:
        print(f"\nNo se encontraron módulos custom en los addons de '{instance}'.")
        return "all"
    
    options = [(mod, mod) for mod in modules]
    selected = prompt_selection(options, f"Selecciona módulos a actualizar para '{instance}' (Espacio para marcar, Enter para confirmar)", multi=True)
    if not selected:
        return "all"
    return ",".join(selected)


def main():
    os.chdir(BASE_PATH)

    parser = argparse.ArgumentParser(
        description="Multi-instance Odoo Docker management CLI."
    )
    subparsers = parser.add_subparsers(dest="action", help="Comandos disponibles")

    # build
    build_p = subparsers.add_parser("build", help="Genera configs y construye imágenes Docker")
    build_p.add_argument("--no-cache", action="store_true", help="Construir sin caché")

    # start
    start_p = subparsers.add_parser("start", help="Inicia instancia(s) de Odoo")
    start_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional, sin argumento inicia todas)")

    # stop
    stop_p = subparsers.add_parser("stop", help="Detiene instancia(s) de Odoo")
    stop_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # restart
    restart_p = subparsers.add_parser("restart", help="Reinicia instancia(s) de Odoo")
    restart_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # bash
    bash_p = subparsers.add_parser("bash", help="Abre bash en un contenedor Odoo")
    bash_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # logs
    logs_p = subparsers.add_parser("logs", help="Muestra logs en tiempo real")
    logs_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # list
    subparsers.add_parser("list", help="Lista contenedores en ejecución")

    # remove
    remove_p = subparsers.add_parser("remove", help="Elimina contenedores y volúmenes")
    remove_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # fix-files
    fix_p = subparsers.add_parser("fix-files", help="Corrige permisos del filestore")
    fix_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # psql
    psql_p = subparsers.add_parser("psql", help="Conectar a PostgreSQL")
    psql_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")
    psql_p.add_argument("-d", required=True, help="Nombre de la base de datos")

    # pw
    pw_p = subparsers.add_parser("pw", help="Restablecer contraseña de un usuario")
    pw_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")
    pw_p.add_argument("-d", required=False, help="Nombre de la base de datos (opcional)")
    pw_p.add_argument("-l", help="Login a restablecer (opcional)")
    pw_p.add_argument("-p", "--password", default="admin", help="Nueva contraseña (por defecto: admin)")

    # update
    update_p = subparsers.add_parser("update", help="Actualizar módulos de Odoo")
    update_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")
    update_p.add_argument("-d", required=False, help="Nombre de la base de datos (opcional)")
    update_p.add_argument("-m", default=None, help="Módulos a actualizar (opcional)")

    # init
    init_p = subparsers.add_parser("init", help="Inicializar addons/repositorios")
    init_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # sync
    sync_p = subparsers.add_parser("sync", help="Sincroniza submódulos de un repositorio")
    sync_p.add_argument("r", nargs="?", default=None, help="Repositorio (opcional)")
    sync_p.add_argument("b", nargs="?", default=None, help="Branch (opcional)")
    sync_p.add_argument("--v", action="store_true", default=False, help="Mostrar salida de git")

    args = parser.parse_args()

    if not args.action:
        parser.print_help()
        return

    # Load config for all commands
    config = load_config(BASE_PATH)

    actions_with_instance = {
        "start", "stop", "restart", "logs", "remove", 
        "fix-files", "init", "bash", "psql", "pw", "update"
    }
    
    if args.action in actions_with_instance and getattr(args, "instance", None) is None:
        args.instance = prompt_for_instance(config, args.action)

    # Dispatch
    if args.action == "build":
        build_odoo(config, args.no_cache)
    elif args.action == "start":
        start_odoo(config, args.instance)
    elif args.action == "stop":
        stop_odoo(config, args.instance)
    elif args.action == "restart":
        restart_odoo(config, args.instance)
    elif args.action == "bash":
        run_bash(config, args.instance)
    elif args.action == "logs":
        show_logs(config, args.instance)
    elif args.action == "list":
        list_containers(config)
    elif args.action == "remove":
        remove_odoo(config, args.instance)
    elif args.action == "fix-files":
        fix_filestore(config, args.instance)
    elif args.action == "psql":
        psql_connect(config, args.instance, args.d)
    elif args.action == "pw":
        if args.d is None:
            args.d = prompt_for_database(config, args.instance)
        if args.l is None:
            args.l = prompt_for_user(config, args.instance, args.d)
        reset_password(config, args.instance, args.d, args.l, args.password)
    elif args.action == "update":
        if args.instance is None:
            args.instance = prompt_for_instance(config, "update")
        if args.d is None:
            args.d = prompt_for_database(config, args.instance)
        if args.m is None:
            args.m = prompt_for_modules(config, args.instance)
        bash_update_modules(config, args.instance, args.d, args.m)
    elif args.action == "init":
        init_addons(config, args.instance)
    elif args.action == "sync":
        if args.r is None:
            args.r = prompt_for_repos()
        if args.b is None:
            args.b = prompt_for_branch(args.r if isinstance(args.r, str) else None)
        sync(args.r, args.b, show=args.v)


if __name__ == "__main__":
    main()
