def psql(d):
    print(d)
    PROJECT_NAME = os.getenv("PROJECT_NAME")
    POSTGRES_USER = os.getenv("POSTGRES_USER")
    POSTGRES_PASSWORD = os.getenv("POSTGRES_PASSWORD")
    os.system(
        f"docker exec -it -e PGPASSWORD={POSTGRES_PASSWORD} {PROJECT_NAME} psql --host {PROJECT_NAME}_db -U {POSTGRES_USER} -d {d}"
    )


def main():
    load_dotenv()

    parser = argparse.ArgumentParser(description="Script para controlar Odoo.")
    subparsers = parser.add_subparsers(dest="action", help="Acciones")

    subparsers.add_parser("start", help="Ejecuta Odoo")
    subparsers.add_parser("stop", help="Detiene Odoo")
    subparsers.add_parser("restart", help="Reiniciar Odoo")
    subparsers.add_parser("fix-files", help="Arreglar permisos de propiedad de filestore")
    subparsers.add_parser("bash", help="Bash")
    subparsers.add_parser("init", help="Clone repositories")
    subparsers.add_parser("logs", help="Muestra los últimos 10 logs en tiempo real")
    subparsers.add_parser("list", help="Lista los contenedores en ejecución")
    subparsers.add_parser("remove", help="Elimina los contenedores de Odoo y la base de datos")

    build_parser = subparsers.add_parser("build", help="Construye Odoo")
    build_parser.add_argument("--no-cache", action="store_true", help="Construir sin usar caché")

    psql_parser = subparsers.add_parser("psql", help="psql")
    psql_parser.add_argument("-d", required=True, help="Database name")

    # ==========================================
    # MODIFICACIÓN EN EL PARSER
    # ==========================================
    sync_parser = subparsers.add_parser("sync", help="Sync Submodules")
    sync_parser.add_argument("r", nargs="?", default="interactive", help="Repository (ej. edc). Si se omite, abre menú.")
    sync_parser.add_argument("b", nargs="?", default="interactive", help="Branch (ej. staging). Si se omite, abre menú.")
    sync_parser.add_argument("--v", action="store_true", default=False, help="Git log detallado")

    update_parser = subparsers.add_parser("update", help="Update Modules")
    update_parser.add_argument("-d", default="interactive", help="Database name.")
    update_parser.add_argument("-m", default="interactive", help="Modules to update.")

    args = parser.parse_args()

    if args.action == "start":
        start_odoo()
        return True
    if args.action == "stop":
        stop_odoo()
        return True
    if args.action == "restart":
        restart_odoo()
        return True
    if args.action == "fix-files":
        fix_filestore_ownership_odoo()
        return True
    if args.action == "build":
        build_odoo(args.no_cache)
        return True
    if args.action == "bash":
        run_bash()
        return True
    if args.action == "update":
        bash_update_modules(args.d, args.m)
        return True
    if args.action == "init":
        init_addons()
        return True
    if args.action == "psql":
        psql(args.d)
        return True
    if args.action == "sync":
        sync(args.r, args.b, show=args.v)
        return True
    if args.action == "logs":
        show_logs()
        return True
    if args.action == "list":
        list_containers()
        return True
    if args.action == "remove":
        remove_odoo()
        return True

    parser.print_help()
    return False


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\n\n🛑 Proceso cancelado por el usuario.")
        sys.exit(0)