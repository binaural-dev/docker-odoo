def interactive_database_selection():
    PROJECT_NAME = os.getenv("PROJECT_NAME")
    POSTGRES_USER = os.getenv("POSTGRES_USER")
    POSTGRES_PASSWORD = os.getenv("POSTGRES_PASSWORD")

    print(f"\n🔍 Buscando bases de datos en el servidor...")
    cmd = [
        "docker", "exec", "-e", f"PGPASSWORD={POSTGRES_PASSWORD}", PROJECT_NAME,
        "psql", "--host", f"{PROJECT_NAME}_db", "-U", POSTGRES_USER, "-d", "postgres", 
        "-t", "-c", "SELECT datname FROM pg_database WHERE datistemplate = false AND datname != 'postgres';"
    ]
    
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        databases = [db.strip() for db in result.stdout.split('\n') if db.strip()]
    except subprocess.CalledProcessError:
        print("❌ Error al consultar las bases de datos. ¿Están los contenedores encendidos?")
        sys.exit(1)

    if not databases:
        print("❌ No se encontraron bases de datos de Odoo.")
        sys.exit(1)

    print("\n🗄️  Bases de datos disponibles:")
    for i, db in enumerate(databases, 1):
        print(f"  {i}. {db}")

    db_choice = input("\n👉 Selecciona el número de la base de datos (Enter para cancelar): ").strip()
    if not db_choice:
        print("Operación cancelada.")
        sys.exit(0)

    try:
        db_idx = int(db_choice) - 1
        if db_idx < 0 or db_idx >= len(databases):
            raise ValueError
        return databases[db_idx]
    except ValueError:
        print("❌ Selección inválida. Saliendo...")
        sys.exit(1)


def get_parent_directories(base_path):
    parents = []
    if os.path.exists(base_path):
        for d in sorted(os.listdir(base_path)):
            full_path = os.path.join(base_path, d)
            if os.path.isdir(full_path) and not d.startswith('.') and d != 'custom':
                parents.append({'display': f"src/{d}", 'full_path': full_path})
    
    custom_path = os.path.join(base_path, 'custom')
    if os.path.exists(custom_path):
        for d in sorted(os.listdir(custom_path)):
            full_path = os.path.join(custom_path, d)
            if os.path.isdir(full_path) and not d.startswith('.'):
                parents.append({'display': f"src/custom/{d}", 'full_path': full_path})
                
    return parents


def interactive_module_selection():
    base_path = os.path.join(str(Path(__file__).resolve().parent), 'src')
    parents = get_parent_directories(base_path)
    
    if not parents:
        print(f"❌ No se encontraron carpetas padre en '{base_path}'.")
        sys.exit(1)

    print("\n--- ASISTENTE DE ACTUALIZACIÓN DE MÓDULOS ---")
    print("\n📁 Carpetas padre disponibles:")
    for i, p in enumerate(parents, 1):
        print(f"  {i}. {p['display']}")
        
    parent_choice = input("\n👉 Selecciona el número de la carpeta padre (Enter para cancelar): ")
    if not parent_choice.strip():
        print("Operación cancelada.")
        sys.exit(0)
        
    try:
        parent_idx = int(parent_choice.strip()) - 1
        if parent_idx < 0 or parent_idx >= len(parents):
            raise ValueError
        selected_parent = parents[parent_idx]
    except ValueError:
        print("❌ Selección inválida. Saliendo...")
        sys.exit(1)

    print(f"\n📂 Escaneando módulos en '{selected_parent['display']}'...")
    modules = []
    parent_full_path = selected_parent['full_path']
    
    for d in os.listdir(parent_full_path):
        mod_path = os.path.join(parent_full_path, d)
        if os.path.isdir(mod_path) and os.path.exists(os.path.join(mod_path, '__manifest__.py')):
            modules.append(d)
            
    modules.sort()
    
    if not modules:
        print(f"❌ No se encontraron módulos en '{selected_parent['display']}'.")
        sys.exit(1)

    print("\n📦 Módulos disponibles:")
    for i, mod in enumerate(modules, 1):
        print(f"  {i}. {mod}")
        
    print("\n💡 Ingresa los números separados por espacios o comas (Ej: 1, 4, 5)")
    print("💡 O escribe 'all' para actualizar TODOS los módulos listados.")
    mod_choices = input("👉 Módulos a actualizar: ").strip()
    
    if not mod_choices:
        print("❌ Ningún módulo seleccionado. Saliendo...")
        sys.exit(1)
        
    if mod_choices.lower() == 'all':
        return ",".join(modules)

    selected_modules = []
    raw_numbers = mod_choices.replace(',', ' ').split()
    
    for num_str in raw_numbers:
        try:
            mod_idx = int(num_str.strip()) - 1
            if 0 <= mod_idx < len(modules):
                if modules[mod_idx] not in selected_modules:
                    selected_modules.append(modules[mod_idx])
            else:
                print(f"  [!] Número {num_str} fuera de rango.")
        except ValueError:
            print(f"  [!] '{num_str}' no es un número válido.")
            
    if not selected_modules:
        print("❌ Ningún módulo seleccionado.")
        sys.exit(1)
        
    return ",".join(selected_modules)


def bash_update_modules(dbname: str = "interactive", modules: str = "interactive"):
    if dbname == "interactive":
        dbname = interactive_database_selection()

    if modules == "interactive":
        modules = interactive_module_selection()
        
    PROJECT_NAME = os.getenv("PROJECT_NAME")
    
    print(f"\n🚀 Ejecutando actualización en BD: {dbname}")
    print(f"📦 Módulos: {modules}\n")
    
    cmd = f"docker exec -u root -it {PROJECT_NAME} odoo --stop-after-init -p 90 --workers=0 -u {modules} -d {dbname}"
    print(cmd)
    os.system(cmd)


