# FUNCION SYNC PRINCIPAL
# ==========================================
def sync(repo_name_arg="interactive", branch="interactive", show=False):
    path = str(Path(__file__).resolve().parent)
    src_path = os.path.join(path, "src")
    
    # 1. Resolución de Repositorio (Interactiva o Difusa)
    if repo_name_arg == "interactive":
        repo_data = interactive_sync_repo_selection(src_path)
        repo_name = repo_data['repo_name']
        repo_path = repo_data['repo_path']
    else:
        direct_path = os.path.join(src_path, repo_name_arg)
        custom_path = os.path.join(src_path, "custom", repo_name_arg)
        
        if os.path.isdir(os.path.join(direct_path, ".git")):
            repo_path = direct_path
            repo_name = repo_name_arg
        elif os.path.isdir(os.path.join(custom_path, ".git")):
            repo_path = custom_path
            repo_name = f"custom/{repo_name_arg}"
        else:
            found = False
            custom_dir = os.path.join(src_path, "custom")
            if os.path.exists(custom_dir):
                for d in os.listdir(custom_dir):
                    if os.path.isdir(os.path.join(custom_dir, d, ".git")) and repo_name_arg.lower() in d.lower():
                        repo_path = os.path.join(custom_dir, d)
                        repo_name = f"custom/{d}"
                        found = True
                        print(f"💡 Resolviendo repositorio: '{repo_name_arg}' -> '{repo_name}'")
                        break
            if not found:
                print(f"❌ Error: No se encuentra un repositorio que coincida con '{repo_name_arg}'")
                return

    # 2. Selección de Rama
    if branch == "interactive":
        branch = interactive_sync_branch_selection(repo_path)

    print(f"\n🚀 Iniciando sincronización...")
    print(f"📁 Repositorio: {repo_name}")
    print(f"🌿 Rama destino: {branch}\n")

    os.chdir(repo_path)

    stdout = subprocess.DEVNULL if not show else None
    stderr = subprocess.STDOUT if not show else None

    print(f"\r {repo_name}: Guardando cambios actuales... ", end=" " * 30)
    value = subprocess.run(["git", "status"], capture_output=True)
    values_lines = value.stdout.decode().split("\n")
    branch_now = values_lines[0].replace("On branch ", "")

    print(f"\r {repo_name}: Cambiando a {branch}                                ", end=" " * 30)
    subprocess.run(["git", "stash"], stdout=stdout, stderr=stderr)
    subprocess.run(["git", "checkout", branch], stdout=stdout, stderr=stderr)
    subprocess.run(["git", "pull"], stdout=stdout, stderr=stderr)

    # 3. Detección Dinámica de Submodulos (.gitmodules)
    submodules = []
    if os.path.exists(".gitmodules"):
        try:
            result = subprocess.run(
                ["git", "config", "--file", ".gitmodules", "--get-regexp", "path"], 
                capture_output=True, text=True, check=True
            )
            for line in result.stdout.strip().split('\n'):
                if line:
                    key, path_val = line.split(' ', 1)
                    name = key.split('.')[1]
                    submodules.append({"name": name, "path": path_val})
        except subprocess.CalledProcessError:
            pass
    
    if submodules:
        print(f"\r {repo_name}: Actualizando {len(submodules)} submodulos detectados... ", end=" " * 30)
        for sub in submodules:
            sub_path = sub["path"]
            subprocess.run(["git", "reset", "HEAD", "--", sub_path], stdout=stdout, stderr=stderr)
            subprocess.run(["git", "-C", sub_path, "stash", "--include-untracked"], stdout=stdout, stderr=stderr)
            subprocess.run(["git", "submodule", "update", "--init", "--force", "--", sub_path], stdout=stdout, stderr=stderr)

        print("")
        
        # 4. Sincronización de carpetas compartidas globales
        for sub in submodules:
            sub_name = sub["name"]
            sub_path = sub["path"]
            
            try:
                commit_res = subprocess.run(["git", "rev-parse", f"HEAD:{sub_path}"], capture_output=True, text=True, check=True)
                commit = commit_res.stdout.strip()
            except subprocess.CalledProcessError:
                continue
            
            if not commit:
                continue

            global_candidates = [
                os.path.join(src_path, sub_path),
                os.path.join(src_path, sub_name),
                os.path.join(src_path, "custom", sub_path),
                os.path.join(src_path, "custom", sub_name)
            ]
            
            global_repo = None
            for cand in global_candidates:
                if os.path.isdir(cand) and os.path.isdir(os.path.join(cand, ".git")):
                    global_repo = cand
                    break
            
            if not global_repo:
                if show:
                    print(f"  -> Omite {sub_name}: No se encontró como directorio global en src/")
                continue

            if not show:
                print(f"\r {sub_name} Sincronizando directorio global... ", end="")
            
            os.chdir(global_repo)
            try:
                subprocess.run(["git", "stash"], stdout=stdout, stderr=stderr)
                subprocess.run(["git", "fetch"], stdout=stdout, stderr=stderr)
                subprocess.run(["git", "checkout", commit], stdout=stdout, stderr=stderr)
                
                current_commit = subprocess.run(["git", "rev-parse", "HEAD"], capture_output=True, text=True).stdout.strip()
                if current_commit != commit:
                    print(f"\nERROR: No se pudo hacer checkout a {commit[:7]} en {global_repo}")
                    raise Exception("Checkout error")

                if not show:
                    print(f"\r {sub_name} ( {commit[:7]} ) Sincronizado ✅" + " " * 30)
            except Exception as a:
                if show:
                    print(a)
                if not show:
                    print(f"\r {sub_name} ( {commit[:7]} ) Sincronizado Fallido ❌" + " " * 30)
    else:
        print(f"\r {repo_name}: Sin submodulos para actualizar.                 ", end=" " * 30)
        print("")

    os.chdir(repo_path)
    subprocess.run(["git", "checkout", branch_now], stdout=stdout, stderr=stderr)
    subprocess.run(["git", "stash", "pop"], stdout=stdout, stderr=stderr)
    print("\n✅ Proceso de sincronización finalizado.\n")


