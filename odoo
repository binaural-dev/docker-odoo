    """Update Odoo modules in an instance."""
    container = f"odoo-{instance}"
    cmd = f"docker exec -u root -it {container} odoo --stop-after-init -p 90 --workers=0 -u {modules} -d {dbname}"
    print(cmd)
    os.system(cmd)


def show_logs(config, instance=None):
    """Show logs for instance(s)."""
    if instance:
        services = _get_instance_services(config, instance)
        db_services = _get_db_services(config, instance)
        all_services = db_services + services
        _docker_compose("logs", "--tail=10", "-f", *all_services)
    else:
        _docker_compose("logs", "--tail=10", "-f")


def list_containers(config):
