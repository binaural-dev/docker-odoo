def interactive_sync_repo_selection(src_path):
    """Permite seleccionar de forma interactiva un repositorio Git en src o src/custom"""
    parents = []
    if os.path.exists(src_path):
        parents.append({'display': 'src/', 'path': src_path})
    
    custom_path = os.path.join(src_path, 'custom')
    if os.path.exists(custom_path):
        parents.append({'display': 'src/custom/', 'path': custom_path})
        
    if not parents:
        print(f"❌ No se encontraron las rutas esperadas en {src_path}")
        sys.exit(1)

    print("\n--- ASISTENTE DE SINCRONIZACIÓN ---")
    print("\n📁 ¿Dónde está el repositorio que deseas sincronizar?:")
    for i, p in enumerate(parents, 1):
        print(f"  {i}. {p['display']}")
        
    parent_choice = input("\n👉 Selecciona la ruta (Enter para cancelar): ").strip()
    if not parent_choice:
        print("Operación cancelada.")
        sys.exit(0)
        
    try:
        parent_idx = int(parent_choice) - 1
        if parent_idx < 0 or parent_idx >= len(parents):
            raise ValueError
        selected_parent = parents[parent_idx]
    except ValueError:
        print("❌ Selección inválida.")
        sys.exit(1)

    # Buscar repositorios Git en la ruta elegida
    repos = []
    parent_full_path = selected_parent['path']
    for d in sorted(os.listdir(parent_full_path)):
        full_path = os.path.join(parent_full_path, d)
        if os.path.isdir(full_path) and os.path.isdir(os.path.join(full_path, '.git')):
            repos.append(d)
            
    if not repos:
        print(f"❌ No se encontraron repositorios Git en '{selected_parent['display']}'.")
        sys.exit(1)

    print(f"\n📦 Repositorios disponibles en {selected_parent['display']}:")
    for i, r in enumerate(repos, 1):
        print(f"  {i}. {r}")
        
    repo_choice = input("\n👉 Selecciona el número del repositorio: ").strip()
    try:
        repo_idx = int(repo_choice) - 1
        if 0 <= repo_idx < len(repos):
            repo_name = repos[repo_idx]
            display_name = f"custom/{repo_name}" if selected_parent['display'] == 'src/custom/' else repo_name
            return {
                'repo_name': display_name,
                'repo_path': os.path.join(parent_full_path, repo_name)
            }
        else:
            raise ValueError
    except ValueError:
        print("❌ Selección inválida.")
        sys.exit(1)

def interactive_sync_branch_selection(repo_path):
    """Busca las ramas locales del repo y permite seleccionar o escribir una"""
    print(f"\n📂 Buscando ramas locales...")
    try:
        result = subprocess.run(
            ["git", "-C", repo_path, "branch", "--format=%(refname:short)"],
            capture_output=True, text=True, check=True
        )
        branches = [b.strip() for b in result.stdout.split('\n') if b.strip()]
    except subprocess.CalledProcessError:
        print("❌ Error al consultar las ramas de Git.")
        sys.exit(1)

    if not branches:
        print("⚠️  No se encontraron ramas locales.")
        manual_branch = input("👉 Escribe el nombre exacto de la rama a sincronizar: ").strip()
        if manual_branch:
            return manual_branch
        sys.exit(1)

    print("\n🌿 Ramas locales disponibles:")
    for i, b in enumerate(branches, 1):
        print(f"  {i}. {b}")
    
    manual_idx = len(branches) + 1
    print(f"  {manual_idx}. ✍️  Escribir una rama manualmente")

    choice = input("\n👉 Selecciona el número o escribe el nombre de la rama: ").strip()
    if not choice:
        print("Operación cancelada.")
        sys.exit(0)

    try:
        idx = int(choice) - 1
        if idx == len(branches):
            manual_branch = input("👉 Escribe el nombre exacto de la rama: ").strip()
            if manual_branch:
                return manual_branch
            else:
                print("❌ Operación cancelada por rama vacía.")
                sys.exit(1)
        elif 0 <= idx < len(branches):
            return branches[idx]
        else:
            print("❌ Selección de número fuera de rango.")
            sys.exit(1)
    except ValueError:
        print(f"💡 Resolviendo entrada manual: '{choice}'")
        return choice

