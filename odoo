# Main CLI
# ============================================================


def prompt_for_instance(config, action):
    instances = list(config.get("instances", {}).keys())
    if not instances:
        print("No hay instancias configuradas.")
        sys.exit(1)

    allow_all_actions = {"start", "stop", "restart", "logs", "remove", "fix-files", "init"}
    allow_all = action in allow_all_actions

    print("\nInstancias disponibles:")
    if allow_all:
        print("  0. Todas las instancias")
    
    for i, name in enumerate(instances, 1):
        print(f"  {i}. {name}")

    min_val = 0 if allow_all else 1
    
    while True:
        try:
            choice = input(f"\nSelecciona una instancia ({min_val}-{len(instances)}): ")
            if not choice.strip():
                continue
            idx = int(choice)
            if allow_all and idx == 0:
                return None
            if 1 <= idx <= len(instances):
                return instances[idx - 1]
            print(f"Selección inválida. Debe ser un número entre {min_val} y {len(instances)}.")
        except ValueError:
            print("Por favor ingresa un número válido.")
        except (KeyboardInterrupt, EOFError):
            print("\nOperación cancelada.")
            sys.exit(0)


def main():
    os.chdir(BASE_PATH)

    parser = argparse.ArgumentParser(
        description="Multi-instance Odoo Docker management CLI."
    )
    subparsers = parser.add_subparsers(dest="action", help="Comandos disponibles")

    # build
    build_p = subparsers.add_parser("build", help="Genera configs y construye imágenes Docker")
    build_p.add_argument("--no-cache", action="store_true", help="Construir sin caché")

    # start
    start_p = subparsers.add_parser("start", help="Inicia instancia(s) de Odoo")
    start_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional, sin argumento inicia todas)")

    # stop
    stop_p = subparsers.add_parser("stop", help="Detiene instancia(s) de Odoo")
    stop_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # restart
    restart_p = subparsers.add_parser("restart", help="Reinicia instancia(s) de Odoo")
    restart_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # bash
    bash_p = subparsers.add_parser("bash", help="Abre bash en un contenedor Odoo")
    bash_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # logs
    logs_p = subparsers.add_parser("logs", help="Muestra logs en tiempo real")
    logs_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # list
    subparsers.add_parser("list", help="Lista contenedores en ejecución")

    # remove
    remove_p = subparsers.add_parser("remove", help="Elimina contenedores y volúmenes")
    remove_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # fix-files
    fix_p = subparsers.add_parser("fix-files", help="Corrige permisos del filestore")
    fix_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # psql
    psql_p = subparsers.add_parser("psql", help="Conectar a PostgreSQL")
    psql_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")
    psql_p.add_argument("-d", required=True, help="Nombre de la base de datos")

    # update
    update_p = subparsers.add_parser("update", help="Actualizar módulos de Odoo")
    update_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")
    update_p.add_argument("-d", required=True, help="Nombre de la base de datos")
    update_p.add_argument("-m", default="all", help="Módulos a actualizar (separados por coma)")

    # init
    init_p = subparsers.add_parser("init", help="Inicializar addons/repositorios")
    init_p.add_argument("instance", nargs="?", default=None, help="Nombre de instancia (opcional)")

    # sync
    sync_p = subparsers.add_parser("sync", help="Sincroniza submódulos de un repositorio")
    sync_p.add_argument("r", help="Repositorio")
    sync_p.add_argument("b", help="Branch")
    sync_p.add_argument("--v", action="store_true", default=False, help="Mostrar salida de git")

    args = parser.parse_args()

    if not args.action:
        parser.print_help()
        return

    # Load config for all commands except sync (which doesn't need it)
    if args.action != "sync":
        config = load_config(BASE_PATH)

        actions_with_instance = {
            "start", "stop", "restart", "logs", "remove", 
            "fix-files", "init", "bash", "psql", "update"
        }
        
        if args.action in actions_with_instance and getattr(args, "instance", None) is None:
            args.instance = prompt_for_instance(config, args.action)

    # Dispatch
    if args.action == "build":
        build_odoo(config, args.no_cache)
    elif args.action == "start":
        start_odoo(config, args.instance)
    elif args.action == "stop":
        stop_odoo(config, args.instance)
    elif args.action == "restart":
        restart_odoo(config, args.instance)
    elif args.action == "bash":
        run_bash(config, args.instance)
    elif args.action == "logs":
        show_logs(config, args.instance)
    elif args.action == "list":
        list_containers(config)
    elif args.action == "remove":
        remove_odoo(config, args.instance)
    elif args.action == "fix-files":
        fix_filestore(config, args.instance)
    elif args.action == "psql":
        psql_connect(config, args.instance, args.d)
    elif args.action == "update":
        bash_update_modules(config, args.instance, args.d, args.m)
    elif args.action == "init":
        init_addons(config, args.instance)
    elif args.action == "sync":
        sync(args.r, args.b, show=args.v)


if __name__ == "__main__":
    main()
