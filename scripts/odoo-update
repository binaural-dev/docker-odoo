#!/usr/bin/env python3

import os
import sys
import click
from pathlib import Path

BASE_PATH = str(Path(__file__).resolve().parent.parent)
sys.path.insert(0, os.path.join(BASE_PATH, ".resources"))
from generators.config_loader import load_config


@click.command()
@click.argument("instance")
@click.option("-d", required=True, help="Database name")
@click.argument("modules", nargs=-1)
def run_command(instance, d, modules):
    config = load_config(BASE_PATH)
    if instance not in config["instances"]:
        click.echo(f"Error: instancia '{instance}' no existe")
        sys.exit(1)

    container = f"odoo-{instance}"
    modules_str = ','.join(modules) if modules else 'all'
    os.system(
        f"docker exec -it {container} odoo -d {d} -u {modules_str} --load-language=es_VE --stop-after-init"
    )


if __name__ == "__main__":
    run_command()
