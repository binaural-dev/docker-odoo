#!/usr/bin/env python3

import argparse
import subprocess
import datetime
import os
import sys
import re
import shlex


# ============================================================
# 1. DumpManager: genera dump.sql dentro del contenedor
# ============================================================
class DumpManager:
    def __init__(
        self,
        container_name,
        dump_path,
        db_name,
        db_user,
        db_host,
        db_port,
        copy_to_local_path,
        linux_dump_user,
        target_pg_major,
        pg_dump_bin="pg_dump",
        overwrite_existing=False,
    ):
        self.container = container_name
        self.db_name = db_name
        self.db_user = db_user
        self.db_host = db_host
        self.db_port = db_port
        self.dump_path = dump_path
        self.dump_folder = os.path.dirname(dump_path)
        self.copy_to_local_path = copy_to_local_path
        self.overwrite_existing = overwrite_existing
        self.linux_dump_user = linux_dump_user  # Para crear y eliminar con este usuario. Asi evitamos eliminar archivos importantes.
        self.target_pg_major = str(target_pg_major)
        self.pg_dump_bin = pg_dump_bin

    def _get_pg_dump_major_in_container(self):
        cmd = [
            "docker",
            "exec",
            "-u",
            self.linux_dump_user,
            self.container,
            self.pg_dump_bin,
            "--version",
        ]

        result = subprocess.run(cmd, capture_output=True, text=True)

        if result.returncode != 0:
            stderr = (result.stderr or "").strip()
            raise RuntimeError(
                "No se pudo ejecutar el binario de pg_dump configurado "
                f"('{self.pg_dump_bin}') dentro del contenedor {self.container}. "
                f"Detalle: {stderr or 'sin detalle'}"
            )

        version_output = (result.stdout or "").strip()

        version_match = re.search(r"PostgreSQL\)\s+(\d+)", version_output)
        if not version_match:
            version_match = re.search(r"(\d+)", version_output)

        if not version_match:
            raise RuntimeError(
                "No se pudo interpretar la versión de pg_dump a partir de la salida: "
                f"'{version_output}'"
            )

        return str(int(version_match.group(1)))

    def _validate_pg_dump_major_compatibility(self):
        pg_dump_major = self._get_pg_dump_major_in_container()

        if pg_dump_major != self.target_pg_major:
            raise RuntimeError(
                "ERROR: incompatibilidad de major entre pg_dump y destino.\n\n"
                "Por política del proyecto, el backup debe generarse con la misma\n"
                "major que el PostgreSQL destino para evitar fallas al restaurar.\n\n"
                f"- pg_dump detectado: {pg_dump_major}\n"
                f"- major destino esperada: {self.target_pg_major}\n\n"
                "Acción recomendada:\n"
                "1) Ajustá --pg-dump-bin o --target-pg-major.\n"
                f"2) Ingresá al contenedor: docker exec -it {self.container} bash\n"
                "3) Instalá el cliente correcto:\n"
                "   apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends "
                f"postgresql-client-{self.target_pg_major}\n"
                "4) Reintentá con:\n"
                f"   --pg-dump-bin /usr/lib/postgresql/{self.target_pg_major}/bin/pg_dump"
            )

    def _create_dump_user(self):
        print(
            f"Creando usuario Linux para realizar dump dentro del contenedor {self.container} de forma segura."
        )

        # 1. Verificar si el usuario ya existe
        check_cmd = [
            "docker",
            "exec",
            self.container,
            "bash",
            "-c",
            f"id -u {self.linux_dump_user} >/dev/null 2>&1",
        ]

        user_exists = subprocess.run(check_cmd).returncode == 0

        if user_exists:
            print(
                f"Usuario '{self.linux_dump_user}' ya existe. No se creará nuevamente."
            )
            return

        cmd = [
            "docker",
            "exec",
            "-u",
            "root",
            self.container,
            "useradd",
            "-m",
            "-s",
            "/bin/bash",
            self.linux_dump_user,
        ]

        subprocess.run(cmd, check=True)

        print(f"Usuario '{self.linux_dump_user}' creado correctamente.")

    def create_dump_folder(self):
        print(f"Creando carpeta de dumps dentro del contenedor {self.container}")

        subprocess.run(
            [
                "docker",
                "exec",
                "-u",
                self.linux_dump_user,
                self.container,
                "mkdir",
                "-p",
                self.dump_folder,
            ],
            check=True,
        )

    def generate_dump(self):
        self._create_dump_user()
        self._validate_pg_dump_major_compatibility()

        self.create_dump_folder()

        print("Generando dump de la base de datos...")

        pg_dump_bin = shlex.quote(self.pg_dump_bin)

        inner_cmd = (
            f"if [ -f '{self.dump_path}' ]; then "
            f"echo 'ERROR: El archivo {self.dump_path} ya existe.' >&2; exit 1; "
            f"else "
            f"{pg_dump_bin} -h {self.db_host} -p {self.db_port} -U {self.db_user} "
            f"-F p -d {self.db_name} -f {self.dump_path} -b; "
            f"fi"
        )

        overwriting_cmd = (
            f"{pg_dump_bin} -h {self.db_host} -p {self.db_port} -U {self.db_user} "
            f"-F p -d {self.db_name} -f {self.dump_path} -b; "
        )

        dump_cmd = overwriting_cmd if self.overwrite_existing else inner_cmd

        cmd = [
            "docker",
            "exec",
            "-u",
            self.linux_dump_user,
            self.container,
            "bash",
            "-c",
            dump_cmd,
        ]

        print(f"Generando dump.sql dentro del contenedor {self.container}")

        print(f"Ejecutando comando: {' '.join(cmd)}")

        subprocess.run(cmd, check=True)
        return self.dump_path

    def copy_dump_to_local(self):
        print(
            f"Copiando dump.sql desde el contenedor {self.container} a local path {self.copy_to_local_path}"
        )

        if os.path.exists(self.copy_to_local_path) and not self.overwrite_existing:
            raise FileExistsError(
                f"El archivo local {self.copy_to_local_path} ya existe. Debe ser eliminado o especificar otro path local."
            )

        subprocess.run(
            ["mkdir", "-p", os.path.dirname(self.copy_to_local_path)], check=True
        )

        subprocess.run(
            [
                "docker",
                "cp",
                f"{self.container}:{self.dump_path}",
                self.copy_to_local_path,
            ],
            check=True,
        )


# ============================================================
# 2. FilestoreManager: copia el filestore dentro del contenedor
# ============================================================
class FilestoreManager:

    def __init__(
        self,
        container_name,
        container_filestore_path,
        local_filestore_path,
        overwrite_existing=False,
    ):
        self.container = container_name
        self.container_filestore_path = container_filestore_path
        self.local_filestore_path = local_filestore_path
        self.overwrite_existing = overwrite_existing

    def copy_filestore(self):
        print(f"Copiando filestore dentro del contenedor {self.container}")

        if os.path.exists(self.local_filestore_path) and not self.overwrite_existing:
            raise FileExistsError(
                f"La carpeta local {self.local_filestore_path} ya existe. Debe ser eliminada o especificar otro directorio local."
            )

        print(f"Desde {self.container_filestore_path} a {self.local_filestore_path}")

        subprocess.run(["mkdir", "-p", self.local_filestore_path], check=True)

        cmd = [
            "docker",
            "cp",
            f"{self.container}:{self.container_filestore_path}/.",
            self.local_filestore_path,
        ]

        subprocess.run(
            cmd,
            check=True,
        )

        print(f"Commando ejecutado: {' '.join(cmd)}")

        return self.local_filestore_path


# ============================================================
# 3. ZipManager: crea el archivo ZIP dentro del contenedor
# ============================================================
class ZipManager:

    def __init__(self, zip_path, content_paths: list, overwrite_existing=False, verbose=True):
        self.zip_path = zip_path
        self.zip_folder = os.path.dirname(zip_path)
        self.zip_name = os.path.basename(zip_path)
        self.content_paths = content_paths
        self.overwrite_existing = overwrite_existing
        self.verbose = verbose
        self.zip_initialized = False

    def _prepare_zip_file(self):
        if self.zip_initialized:
            return

        if os.path.isfile(self.zip_path):
            if not self.overwrite_existing:
                print(f"El archivo ZIP {self.zip_path} ya existe. Será sobrescrito.")
                raise FileExistsError(f"El archivo ZIP {self.zip_path} ya existe.")

            os.remove(self.zip_path)

        self.zip_initialized = True

    def _get_base_dir(self, content_paths):
        parent_paths = [os.path.dirname(path.rstrip(os.sep)) for path in content_paths]
        return os.path.commonpath(parent_paths)

    def add_paths_to_zip(self, content_paths):
        print(f"Creando carpeta para el ZIP en {self.zip_folder}")

        if not os.path.exists(self.zip_folder):
            raise FileNotFoundError(f"La carpeta {self.zip_folder} no existe")

        for path in content_paths:
            if not os.path.exists(path):
                raise FileNotFoundError(
                    f"El path {path} no existe y no se puede agregar al ZIP"
                )

        self._prepare_zip_file()

        base_dir = self._get_base_dir(content_paths)
        relative_paths = [os.path.relpath(path, base_dir) for path in content_paths]

        cmd = ["zip", "-r", self.zip_path] + relative_paths

        if not self.verbose:
            print("Modo silencioso activado: no se mostrarán los archivos siendo agregados al ZIP. \n")
            cmd.insert(1, "-q")

        print(f"Commando ZIP: \n\n{' '.join(cmd)}\n\n")

        print(f"Actualizando ZIP {self.zip_name} con contenido: {content_paths}")
        subprocess.run(cmd, check=True, cwd=base_dir)

        return self.zip_path

    def create_zip(self):
        return self.add_paths_to_zip(self.content_paths)


# ============================================================
# 4. CleanupManager: elimina archivos temporales
# ============================================================
class CleanupManager:
    def __init__(
        self,
        container_name=None,
        local_paths_to_cleanup=None,
        container_paths_to_cleanup=None,
        cleanup_enabled=True,
        confirm=False,
        linux_dump_user=None,
    ):
        self.container = container_name
        self.local_paths_to_cleanup = local_paths_to_cleanup
        self.container_paths_to_cleanup = container_paths_to_cleanup
        self.cleanup_enabled = cleanup_enabled
        self.confirm = confirm
        self.linux_dump_user = linux_dump_user

    def _confirm(self, message):

        if not self.confirm:
            return True

        response = input(f"{message} (s/n): ").strip().lower()
        return response == "s"

    def force_confirm(self):
        self.confirm = True

        return self

    def _remove_tracked_path(self, tracked_paths, path):
        if not tracked_paths or not path:
            return tracked_paths

        return [tracked_path for tracked_path in tracked_paths if tracked_path != path]

    def container_cleanup(self):
        print(
            f"*** Limpiando archivos temporales dentro del contenedor {self.container}"
        )

        if not self.cleanup_enabled:
            return

        if not (
            self.container_paths_to_cleanup and self.container and self.linux_dump_user
        ):
            return

        continue_cleanup = self._confirm(
            f"\n\n¿Está seguro de que desea eliminar los archivos temporales dentro del contenedor {self.container}?"
            + "\n Esta acción no se puede deshacer."
            + f"\n\nArchivos/Carpetas a eliminar: {self.container_paths_to_cleanup}\n\n"
        )

        if not continue_cleanup:
            print("Limpieza de contenedor cancelada por el usuario.")
            return

        for path in self.container_paths_to_cleanup:
            print(f"Eliminando archivo/carpeta temporal en contenedor: {path}")
            subprocess.run(
                [
                    "docker",
                    "exec",
                    "-u",
                    self.linux_dump_user,
                    self.container,
                    "rm",
                    "-r",
                    path,
                ],
                check=True,
            )
            

    def cleanup_container_path(self, path):
        if not self.cleanup_enabled:
            return

        if not (path and self.container and self.linux_dump_user):
            return

        print(f"Eliminando archivo/carpeta temporal en contenedor: {path}")
        subprocess.run(
            [
                "docker",
                "exec",
                "-u",
                self.linux_dump_user,
                self.container,
                "rm",
                "-rf",
                path,
            ],
            check=True,
        )

        self.container_paths_to_cleanup = self._remove_tracked_path(
            self.container_paths_to_cleanup, path
        )

    def cleanup_local_path(self, path):
        if not self.cleanup_enabled:
            return

        if not path or not os.path.exists(path):
            return

        if os.path.isfile(path):
            print(f"Eliminando archivo temporal: {path}")
            subprocess.run(["rm", "-f", path], check=True)
            self.local_paths_to_cleanup = self._remove_tracked_path(
                self.local_paths_to_cleanup, path
            )
            return

        if os.path.isdir(path):
            print(f"Eliminando carpeta temporal: {path}")
            subprocess.run(["rm", "-rf", path], check=True)
            self.local_paths_to_cleanup = self._remove_tracked_path(
                self.local_paths_to_cleanup, path
            )

    def local_cleanup(self):
        print("Limpiando archivos temporales locales")

        if not self.cleanup_enabled:
            return

        if not self.local_paths_to_cleanup:
            return

        continue_cleanup = self._confirm(
            f"\n\n¿Está seguro de que desea eliminar los archivos temporales locales?"
            + "\n Esta acción no se puede deshacer."
            + f"\n\nArchivos/Carpetas a eliminar: {self.local_paths_to_cleanup}\n\n"
        )

        if not continue_cleanup:
            print("Limpieza local cancelada por el usuario.")
            return

        for path in self.local_paths_to_cleanup:
            self.cleanup_local_path(path)


# ============================================================
# 5. OdooBackupOrchestrator: clase mayor que usa todas las anteriores
# ============================================================
class OdooBackupOrchestrator:

    def __init__(
        self,
        container_name,
        db_name,
        db_user,
        db_host,
        db_port,
        backup_local_path,
        db_container_dump_path,
        linux_dump_user,
        target_pg_major,
        pg_dump_bin="pg_dump",
        container_filestore_path=None,
        cleanup_enabled=True,
        overwrite_existing=False,
        verbose=True,
    ):
        self.verbose = verbose

        self.backup_local_path = backup_local_path
        self.container = container_name

        self.db_name = db_name
        self.db_user = db_user
        self.db_host = db_host
        self.db_port = db_port
        self.container_filestore_path = (
            f"{container_filestore_path}/{db_name}"
            if container_filestore_path
            else None
        )
        
        self.backup_filename = self._get_backup_filename()
        self.backup_zip_path = self._get_zip_path()

        self.tmp_backup_folder_local_path = f"{self.backup_local_path}/.tmp_{self.backup_filename.replace('.zip', '')}"
        
        self.db_container_dump_path = db_container_dump_path
        self.db_copy_to_local_path = f"{self.tmp_backup_folder_local_path}/dump.sql"
        
        self.local_filestore_path = f"{self.tmp_backup_folder_local_path}/filestore"

        self.content_paths_to_zip = [self.db_copy_to_local_path, self.local_filestore_path]
        
        self.overwrite_existing = overwrite_existing
        self.cleanup_enabled = cleanup_enabled

        self.linux_dump_user = linux_dump_user

        self.dump_manager = DumpManager(
            container_name=container_name,
            dump_path=self.db_container_dump_path,
            copy_to_local_path=self.db_copy_to_local_path,
            db_name=db_name,
            db_user=db_user,
            db_host=db_host,
            db_port=db_port,
            overwrite_existing=self.overwrite_existing,
            linux_dump_user=self.linux_dump_user,
            target_pg_major=target_pg_major,
            pg_dump_bin=pg_dump_bin,
        )

        self.cleanup_manager = CleanupManager(
            container_name=self.container,
            container_paths_to_cleanup=[self.db_container_dump_path],
            local_paths_to_cleanup=[
                self.tmp_backup_folder_local_path,
                # self.db_copy_to_local_path,
                # self.local_filestore_path,
            ],
            cleanup_enabled=self.cleanup_enabled,
            linux_dump_user=self.linux_dump_user,
        )

        if self.container_filestore_path:
            self.filestore_manager = FilestoreManager(
                container_name=self.container,
                container_filestore_path=self.container_filestore_path,
                local_filestore_path=self.local_filestore_path,
                overwrite_existing=self.overwrite_existing,
            )
        else:
            self.filestore_manager = None


        self.zip_manager = ZipManager(
            zip_path=self.backup_zip_path,
            content_paths=self.content_paths_to_zip,
            overwrite_existing=self.overwrite_existing,
            verbose=self.verbose,
        )

    # ---------------------------
    # Generar nombre del ZIP
    # ---------------------------
    
    def _get_backup_filename(self):
        now = datetime.datetime.now()
        timestamp = now.strftime("%Y-%m-%d_%H%M%S")

        suffix = "_fs" if self.container_filestore_path else "_nofs"

        zip_name = f"{self.db_name}_{timestamp}{suffix}.zip"
        
        return zip_name

    def _get_zip_path(self):
        zip_path = os.path.abspath(
            os.path.join(self.backup_local_path, self.backup_filename)
        )

        return zip_path

    def _get_database_dump(self):
        self.dump_manager.generate_dump()
        self.dump_manager.copy_dump_to_local()

        return self.db_copy_to_local_path

    def _cleanup_database_dump(self):
        self.cleanup_manager.cleanup_local_path(self.db_copy_to_local_path)
        self.cleanup_manager.cleanup_container_path(self.db_container_dump_path)

    def _cleanup_filestore(self):
        self.cleanup_manager.cleanup_local_path(self.local_filestore_path)
        
    def tmp_folder_cleanup(self):
        print("Limpiando carpeta temporal local")

        if not self.cleanup_enabled:
            return

        tmp_folder_path = self.tmp_backup_folder_local_path
        if os.path.exists(tmp_folder_path):
            self.cleanup_manager.cleanup_local_path(tmp_folder_path)

    def _get_filestore(self):

        if self.filestore_manager:
            self.filestore_manager.copy_filestore()
            return self.local_filestore_path

        cmd = [
            "mkdir",
            "-p",
            self.local_filestore_path,
        ]

        subprocess.run(cmd, check=True)

        return self.local_filestore_path

    def _create_backup_zip(self):
        zip_path = self._get_zip_path()

        self.zip_manager.create_zip()

        return zip_path

    def _append_to_backup_zip(self, content_paths):
        return self.zip_manager.add_paths_to_zip(content_paths)
    
    def ensure_local_backup_folder(self):
        if not os.path.exists(self.backup_local_path):
            print(f"Creando carpeta local para backup en {self.backup_local_path}")
            os.makedirs(self.backup_local_path, exist_ok=True)

    # ---------------------------
    # Ejecutar proceso completo
    # ---------------------------
    def run_backup(self):
        print("\n=== Iniciando proceso de backup ===\n")
        
        self.ensure_local_backup_folder()

        # 1. Dump
        dump_path = self._get_database_dump()
        self._append_to_backup_zip([dump_path])
        self._cleanup_database_dump()

        # 2. Filestore (si aplica)
        filestore_path = self._get_filestore()
        self._append_to_backup_zip([filestore_path])
        self._cleanup_filestore()
        
        self.tmp_folder_cleanup()

        print(
            "\n✔ Backup generado correctamente.\n"
            f"   Archivo: {self.backup_zip_path}\n"
        )

        print(f"✔ Carpeta destino: {self.backup_local_path}\n")

        return self.backup_zip_path


try:
    from dotenv import load_dotenv
except ModuleNotFoundError:
    raise SystemExit(
        "Missing dependency: python-dotenv. Install it with 'sudo apt-get install python3-dotenv' or 'pip install python-dotenv'."
    )


def get_required_env(name):
    value = os.getenv(name)
    if not value:
        raise RuntimeError(f"Falta la variable de entorno requerida: {name}")
    return value


def list_databases(db_user, db_host, db_port):
    """
    Devuelve una lista de bases de datos disponibles en PostgreSQL dentro del contenedor Docker.
    Usa psql -lqt para obtenerlas.
    """

    cmd = [
        "docker",
        "exec",
        get_required_env("PROJECT_NAME"),
        "psql",
        f"-U{db_user}",
        f"-h{db_host}",
        f"-p{db_port}",
        "-lqt",
    ]

    result = subprocess.run(
        cmd,
        capture_output=True,
        text=True,
        env={**os.environ, "PGPASSWORD": get_required_env("POSTGRES_PASSWORD")},
    )

    if result.returncode != 0:
        print("Error al listar bases de datos:")
        print(result.stderr)
        sys.exit(1)

    dbs = []
    for line in result.stdout.splitlines():
        parts = [p.strip() for p in line.split("|")]
        if (
            len(parts) >= 1
            and parts[0]
            and not parts[0].startswith("template")
            and not parts[0].startswith("postgres")
        ):
            dbs.append(parts[0])

    return dbs


def choose_database(db_list):
    """
    Muestra las bases de datos y permite elegir una.
    """
    print("\nBases de datos disponibles:\n")
    for i, db in enumerate(db_list, start=1):
        print(f"{i}. {db}")

    while True:
        choice = input("\nSeleccione el número de la base de datos: ").strip()
        if choice.isdigit() and 1 <= int(choice) <= len(db_list):
            return db_list[int(choice) - 1]
        print("Selección inválida. Intente nuevamente.")


def normalize_pg_major(value):
    normalized = str(value).strip()

    if not normalized:
        raise ValueError("--target-pg-major no puede estar vacío.")

    if not normalized.isdigit():
        raise ValueError(
            "--target-pg-major debe ser un entero positivo (por ejemplo: 16 o 17)."
        )

    return str(int(normalized))


def backup(
    db_name,
    backup_path,
    target_pg_major,
    pg_dump_bin="pg_dump",
    with_filestore=True,
    cleanup=True,
    verbose=True,
):
    odoo_backup_orchestrator = OdooBackupOrchestrator(
        container_name=get_required_env("PROJECT_NAME"),
        db_name=db_name,
        db_user=get_required_env("POSTGRES_USER"),
        db_host=get_required_env("POSTGRES_HOST"),
        db_port=get_required_env("EXTERNAL_PORT_POSTGRES"),
        backup_local_path=backup_path,
        db_container_dump_path="/tmp/odoo_database_backups/dump.sql",
        container_filestore_path=(
            "/home/odoo/data/filestore" if with_filestore else None
        ),
        cleanup_enabled=cleanup,
        overwrite_existing=True,
        linux_dump_user="dump_user",
        target_pg_major=target_pg_major,
        pg_dump_bin=pg_dump_bin,
        verbose=verbose,
    )

    odoo_backup_orchestrator.run_backup()


def main():
    load_dotenv()

    script_dir = os.path.dirname(os.path.abspath(__file__))
    project_root = os.path.dirname(script_dir)
    default_backup_path = os.path.join(project_root, "backups")

    parser = argparse.ArgumentParser(description="Script de backup de Odoo")

    subparsers = parser.add_subparsers(dest="run", help="Acciones")

    backup_parser = subparsers.add_parser(
        "backup", help="Backup de la base de datos y filestore de Odoo"
    )
    
    backup_parser.add_argument(
        "--verbose",
        action="store_true",
        help="Mostrar mensajes detallados durante el backup",
        default=False,
    )

    backup_parser.add_argument(
        "-d",
        required=False,
        help="Nombre de la base de datos (opcional). Si no se proporciona, se listarán las bases disponibles para elegir.",
    )

    backup_parser.add_argument(
        "-p",
        required=False,
        default=default_backup_path,
        help=f"Path local donde se guardará el backup (default: {default_backup_path})",
    )

    backup_parser.add_argument(
        "--target-pg-major",
        required=True,
        help="Major de PostgreSQL destino para validar compatibilidad del dump (ej: 16, 17)",
    )

    backup_parser.add_argument(
        "--pg-dump-bin",
        required=False,
        default="pg_dump",
        help="Binario pg_dump dentro del contenedor (default: pg_dump)",
    )

    backup_parser.add_argument(
        "--no-fs",
        action="store_true",
        help="No hacer backup del filestore",
        default=False,
    )

    backup_parser.add_argument(
        "--no-cleanup",
        action="store_true",
        help="No eliminar archivos temporales después del backup",
        default=False,
    )

    args = parser.parse_args()

    if args.run != "backup":
        parser.print_help()
        sys.exit(1)

    # Si no se pasa -d, listar y elegir
    if not args.d:
        print("No se especificó base de datos. Listando bases disponibles...")
        dbs = list_databases(
            db_user=get_required_env("POSTGRES_USER"),
            db_host=get_required_env("POSTGRES_HOST"),
            db_port=get_required_env("EXTERNAL_PORT_POSTGRES"),
        )
        if not dbs:
            print("No se encontraron bases de datos.")
            sys.exit(1)

        chosen_db = choose_database(dbs)
        print(f"\nBase de datos seleccionada: {chosen_db}")
        args.d = chosen_db

    try:
        target_pg_major = normalize_pg_major(args.target_pg_major)
    except ValueError as error:
        print(
            "\nError de validación de argumentos:\n"
            f"- {error}\n"
        )
        sys.exit(1)

    pg_dump_bin = args.pg_dump_bin.strip()
    if not pg_dump_bin:
        print(
            "\nError de validación de argumentos:\n"
            "- --pg-dump-bin no puede estar vacío.\n"
        )
        sys.exit(1)

    backup(
        db_name=args.d,
        backup_path=args.p,
        target_pg_major=target_pg_major,
        pg_dump_bin=pg_dump_bin,
        with_filestore=not args.no_fs,
        cleanup=not args.no_cleanup,
        verbose=args.verbose,
    )


if __name__ == "__main__":
    verbose_mode = "--verbose" in sys.argv

    try:
        main()
    except Exception as exc:
        if verbose_mode:
            raise

        print(
            "\nError durante el backup.\n"
            f"Detalle: {exc}\n"
            "Sugerencia: ejecutá con --verbose para ver el stack completo.\n",
            file=sys.stderr,
        )
        raise SystemExit(1)
