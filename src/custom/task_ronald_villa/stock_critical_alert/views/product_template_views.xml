<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_inherit_critical_stock" model="ir.ui.view">
        <field name="name">product.template.form.inherit.critical.stock</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.view_template_property_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']" position="inside">
                <group>
                    <group string="Alertas de Stock" name="stock_alerts">
                        <field name="config_min_stock"/>
                        <field name="is_critical_stock" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
